<?php
error_reporting(E_ALL);
ini_set('display_errors', 1);

$host = "localhost";
$user = "root"; 
$pass = ""; 
$dbname = "hypernest"; // Change this to your actual DB name

$conn = new mysqli($host, $user, $pass, $dbname);

if ($conn->connect_error) {
    die("❌ Database connection failed: " . $conn->connect_error);
} else {
    echo "✅ Database connection successful!<br><br>";
}

$sql = "SELECT id, first_name, last_name, username, email, phone FROM admins";
$result = $conn->query($sql);

if (!$result) {
    die("❌ Query failed: " . $conn->error);
}

if ($result->num_rows > 0) {
    echo "<h3>Admins Table Data:</h3>";
    echo "<table border='1' cellpadding='5'>";
    echo "<tr><th>ID</th><th>First Name</th><th>Last Name</th><th>Username</th><th>Email</th><th>Phone</th></tr>";

    while ($row = $result->fetch_assoc()) {
        echo "<tr>
                <td>{$row['id']}</td>
                <td>{$row['first_name']}</td>
                <td>{$row['last_name']}</td>
                <td>{$row['username']}</td>
                <td>{$row['email']}</td>
                <td>{$row['phone']}</td>
              </tr>";
    }
    echo "</table>";
} else {
    echo "⚠️ No admins found in the database.";
}

$conn->close();
?>
